<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tkiefhaber.news-recap-push</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/thomaskiefhaber/Documents/news-recap-site/scripts/push.sh</string>
    </array>

    <!-- Fire whenever the recap files change. Debounced via ThrottleInterval below. -->
    <key>WatchPaths</key>
    <array>
        <string>/Users/thomaskiefhaber/Documents/news-recap-site/index.html</string>
        <string>/Users/thomaskiefhaber/Documents/news-recap-site/archive</string>
    </array>

    <!-- Don't fire more than once every 60 seconds, so a burst of writes coalesces into one push. -->
    <key>ThrottleInterval</key>
    <integer>60</integer>

    <key>StandardOutPath</key>
    <string>/tmp/news-recap-push.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/news-recap-push.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/thomaskiefhaber</string>
    </dict>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
